{
    "configurations": [
        {
            "type": "aws-sam",
            "request": "direct-invoke",
            "invokeTarget": {
                "target": "template",
                "logicalId": "FuncS3FirmwareDeleted",
                "templatePath": "lambdas/func-s3-firmware-deleted/template.yaml"
            },
            "lambda": {
                "runtime": "python3.13",
                "environmentVariables": {
                    "LOG_LEVEL": "DEBUG",
                    "DYNAMODB_FIRMWARE_TABLE_NAME": "firefly-firmware-local",
                    "DYNAMODB_ENDPOINT": "http://host.docker.internal:4566"
                },
                "payload": {
                    "json": {
                        "Records": [
                            {
                                "s3": {
                                    "object": {
                                        "key": "processed/b2041635-3999-4f23-8ff3-6b485c97245f.zip"
                                    }
                                }
                            }
                        ]
                    }
                }
            },
            "sam": {
                "containerBuild": false,
                "skipNewImageCheck": false
            },
            "api": {
                "httpMethod": "get"
            },
            "noDebug": false,
            "name": "FuncS3FirmwareDeleted"
        },
        {
            "type": "aws-sam",
            "request": "direct-invoke",
            "invokeTarget": {
                "target": "template",
                "logicalId": "FuncS3FirmwareUploaded",
                "templatePath": "lambdas/func-s3-firmware-uploaded/template.yaml"
            },
            "lambda": {
                "runtime": "python3.13",
                "environmentVariables": {
                    "DYNAMODB_FIRMWARE_TABLE_NAME": "firefly-firmware-local",
                    "S3_ENDPOINT": "http://host.docker.internal:4566",
                    "DYNAMODB_ENDPOINT": "http://host.docker.internal:4566"
                },
                "payload": {
                    "json": {
                        "Records": [
                            {
                                "s3": {
                                    "bucket": {
                                        "name": "firefly-firmware-local"
                                    },
                                    "object": {
                                        "key": "incoming/test.zip"
                                    }
                                }
                            }
                        ]
                    }
                }
            },
            "sam": {
                "containerBuild": false,
                "skipNewImageCheck": false
            },
            "api": {
                "httpMethod": "get"
            },
            "noDebug": false,
            "name": "FuncS3FirmwareUploaded"
        }
    ]
}