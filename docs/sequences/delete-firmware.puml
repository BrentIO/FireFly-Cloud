@startuml DELETE /firmware/{zip_name}

title DELETE /firmware/{zip_name}

actor Client
participant "API Gateway" as APIGW
participant "func-api-firmware-delete" as DeleteLambda
participant "func-s3-firmware-deleted" as DeletedLambda
database DynamoDB
storage S3

== Successful deletion (non-released firmware) ==

Client -> APIGW : DELETE /firmware/550e8400-...zip
APIGW -> DeleteLambda : invoke
DeleteLambda -> DynamoDB : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"
DynamoDB --> DeleteLambda : item\n{pk, version,\n release_status: "READY_TO_TEST", ...}
DeleteLambda -> DeleteLambda : release_status not in {DELETED, REVOKED} ✓\nprefix = "processed/"
DeleteLambda -> S3 : DeleteObject\nKey: processed/550e8400-...zip
S3 --> DeleteLambda : success
DeleteLambda --> APIGW : 202 Accepted\n{"message": "Deletion initiated"}
APIGW --> Client : 202 Accepted

note over S3, DeletedLambda
  Async: S3 fires ObjectRemoved event
end note

S3 -> DeletedLambda : S3 ObjectRemoved event\n(processed/550e8400-...zip)
DeletedLambda -> DynamoDB : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"
DynamoDB --> DeletedLambda : item\n{release_status: "READY_TO_TEST"}
DeletedLambda -> DeletedLambda : release_status != RELEASED\nnew_status = "DELETED"
DeletedLambda -> DynamoDB : UpdateItem\nKey: {pk, version}\nSET release_status = "DELETED", ttl = now + 10 days

== Successful deletion (released firmware → REVOKED) ==

Client -> APIGW : DELETE /firmware/550e8400-...zip
APIGW -> DeleteLambda : invoke
DeleteLambda -> DynamoDB : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"
DynamoDB --> DeleteLambda : item\n{release_status: "RELEASED", ...}
DeleteLambda -> S3 : DeleteObject\nKey: processed/550e8400-...zip
S3 --> DeleteLambda : success
DeleteLambda --> APIGW : 202 Accepted
APIGW --> Client : 202 Accepted

S3 -> DeletedLambda : S3 ObjectRemoved event\n(processed/550e8400-...zip)
DeletedLambda -> DynamoDB : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"
DynamoDB --> DeletedLambda : item\n{release_status: "RELEASED"}
DeletedLambda -> DeletedLambda : release_status == RELEASED\nnew_status = "REVOKED"
DeletedLambda -> DynamoDB : UpdateItem\nKey: {pk, version}\nSET release_status = "REVOKED", ttl = now + 10 days

== Already removed ==

Client -> APIGW : DELETE /firmware/550e8400-...zip
APIGW -> DeleteLambda : invoke
DeleteLambda -> DynamoDB : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"
DynamoDB --> DeleteLambda : item\n{release_status: "DELETED", ...}
DeleteLambda -> DeleteLambda : release_status in {DELETED, REVOKED} ✗
DeleteLambda --> APIGW : 409 Conflict\n{"message": "Firmware is already in state 'DELETED'..."}
APIGW --> Client : 409 Conflict

== Not found ==

Client -> APIGW : DELETE /firmware/00000000-...zip
APIGW -> DeleteLambda : invoke
DeleteLambda -> DynamoDB : Query GSI zip_name-index\nKeyCondition: zip_name = "00000000-...zip"
DynamoDB --> DeleteLambda : (no items)
DeleteLambda --> APIGW : 404 Not Found
APIGW --> Client : 404 Not Found

@enduml
