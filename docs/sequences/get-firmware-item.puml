@startuml GET /firmware/{product_id}/{version}

title GET /firmware/{product_id}/{version}

actor Client
participant "API Gateway" as APIGW
participant "func-api-firmware-get" as Lambda
database DynamoDB

== Found ==

Client -> APIGW : GET /firmware/firefly-controller-v2/1.4.2
APIGW -> Lambda : invoke
Lambda -> DynamoDB : GetItem\nKey: {product_id, version}
DynamoDB --> Lambda : item (full record including files[])
Lambda --> APIGW : 200 OK\n{full firmware record}
APIGW --> Client : 200 OK\n{full firmware record}

== Not found ==

Client -> APIGW : GET /firmware/firefly-controller-v2/9.9.9
APIGW -> Lambda : invoke
Lambda -> DynamoDB : GetItem\nKey: {product_id, version}
DynamoDB --> Lambda : (no item)
Lambda --> APIGW : 404 Not Found\n{"message": "Firmware not found: ..."}
APIGW --> Client : 404 Not Found

@enduml
