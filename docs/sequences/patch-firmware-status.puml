@startuml PATCH /firmware/{product_id}/{version}/status

title PATCH /firmware/{product_id}/{version}/status

actor Client
participant "API Gateway" as APIGW
participant "func-api-firmware-status-patch" as Lambda
database DynamoDB

== Valid transition (e.g. READY_TO_TEST → TESTING) ==

Client -> APIGW : PATCH /firmware/firefly-controller-v2/1.4.2/status\n{"release_status": "TESTING"}
APIGW -> Lambda : invoke
Lambda -> DynamoDB : GetItem\nKey: {product_id, version}
DynamoDB --> Lambda : item\n{release_status: "READY_TO_TEST", ...}
Lambda -> Lambda : validate transition\nREADY_TO_TEST → TESTING ✓
Lambda -> DynamoDB : UpdateItem\nSET release_status = "TESTING"
DynamoDB --> Lambda : success
Lambda --> APIGW : 200 OK\n{updated firmware record}
APIGW --> Client : 200 OK\n{updated firmware record}

== Invalid transition ==

Client -> APIGW : PATCH /firmware/firefly-controller-v2/1.4.2/status\n{"release_status": "RELEASED"}
APIGW -> Lambda : invoke
Lambda -> DynamoDB : GetItem\nKey: {product_id, version}
DynamoDB --> Lambda : item\n{release_status: "READY_TO_TEST", ...}
Lambda -> Lambda : validate transition\nREADY_TO_TEST → RELEASED ✗
Lambda --> APIGW : 422 Unprocessable Entity\n{"message": "Cannot transition from 'READY_TO_TEST' to 'RELEASED'",\n "allowed_transitions": ["TESTING"]}
APIGW --> Client : 422 Unprocessable Entity

== Firmware not found ==

Client -> APIGW : PATCH /firmware/unknown/9.9.9/status\n{"release_status": "TESTING"}
APIGW -> Lambda : invoke
Lambda -> DynamoDB : GetItem\nKey: {product_id, version}
DynamoDB --> Lambda : (no item)
Lambda --> APIGW : 404 Not Found\n{"message": "Firmware not found: ..."}
APIGW --> Client : 404 Not Found

== State transition reference ==

note over Client, DynamoDB
  Valid transitions (human-initiated via this endpoint):
  READY_TO_TEST → TESTING
  TESTING       → RELEASED
  RELEASED      → REVOKED

  Automatic transitions (event-driven, not via this endpoint):
  upload success → READY_TO_TEST  (func-s3-firmware-uploaded)
  upload failure → ERROR          (func-s3-firmware-uploaded)
  S3 file removed (was RELEASED)  → REVOKED  (func-s3-firmware-deleted)
  S3 file removed (other states)  → DELETED  (func-s3-firmware-deleted)
end note

@enduml
